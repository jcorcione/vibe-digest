{
  "name": "vibe-digest",
  "displayName": "Vibe Digest",
  "description": "Generates a newsletter-style digest of your vibe projects",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "newsletter.exportPdf",
        "title": "Export Digest as PDF"
      }
    ],
    "keybindings": [
      {
        "command": "newsletter.exportPdf",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p"
      }
    ],
    "configuration": {
      "title": "Vibe Digest",
      "properties": {
        "vibeDigest.licenseKey": {
          "type": "string",
          "default": "",
          "description": "Pro license key for Vibe Digest. Required for Pro features such as PDF export."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
