{
  "name": "vibe-digest",
  "displayName": "Vibe Digest",
  "description": "Aggregate newsletters and RSS feeds into a markdown digest inside VS Code",
  "version": "0.1.0",
  "publisher": "jcorcione",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:newsletter.digest"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "newsletter.digest",
        "title": "Vibe Digest: Generate Newsletter Digest"
      }
    ],
    "keybindings": [
      {
        "command": "newsletter.digest",
        "key": "ctrl+alt+n",
        "mac": "ctrl+alt+n"
      }
    ],
    "configuration": {
      "title": "Vibe Digest",
      "properties": {
        "vibeDigest.rssUrls": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of RSS feed URLs to include in the digest"
        },
        "vibeDigest.autoRun": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run the digest on a schedule"
        },
        "vibeDigest.cron": {
          "type": "string",
          "default": "0 8 * * *",
          "description": "Cron expression for auto-run schedule (e.g. '0 8 * * *' for 8 AM daily)"
        },
        "vibeDigest.licenseKey": {
          "type": "string",
          "default": "",
          "description": "Vibe Digest Pro license key"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npx jest && pytest python/tests/ -v",
    "package": "vsce package",
    "setup": "cd python && python -m venv .venv && .venv/bin/pip install -r requirements.txt"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.92.0",
    "@vscode/test-electron": "^2.3.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.4.0",
    "vsce": "^2.15.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^vscode$": "<rootDir>/__mocks__/vscode.ts"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
    }
  }
}
