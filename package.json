{
  "name": "vibe-digest",
  "displayName": "Vibe Digest",
  "description": "Fetches Gmail newsletters & RSS feeds and aggregates them into a markdown digest in your workspace.",
  "version": "0.1.0",
  "publisher": "your-publisher-name",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onCommand:newsletter.digest"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "newsletter.digest",
        "title": "Generate Newsletter Digest"
      }
    ],
    "keybindings": [
      {
        "command": "newsletter.digest",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Vibe Digest",
      "properties": {
        "vibeDigest.rssUrls": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "List of RSS feed URLs to include in the digest."
        },
        "vibeDigest.autoRun": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run the digest on a schedule."
        },
        "vibeDigest.cron": {
          "type": "string",
          "default": "0 8 * * *",
          "description": "Cron expression for auto-run schedule (default: every day at 8am)."
        },
        "vibeDigest.licenseKey": {
          "type": "string",
          "default": "",
          "description": "(Pro) License key for unlocking Pro features."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js && pytest python/tests/ -v",
    "package": "vsce package",
    "setup": "cd python && python -m venv .venv && .venv/bin/pip install -r requirements.txt"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.92.0",
    "@vscode/test-electron": "^2.3.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.4.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {}
}
